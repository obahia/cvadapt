# CVAdapt API Configuration
# ⚠️ IMPORTANT: Never commit actual secrets! This file should only contain examples.

# AI Provider Selection (gemini | claude)
AI_PROVIDER=gemini

# Gemini API Key (required if using Gemini)
# Obtain at: https://ai.google.dev/
# Format: AIzaSy... (never commit real keys)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude API Key (required if using Claude)
# Obtain at: https://console.anthropic.com/
# Format: sk-ant-... (never commit real keys)
CLAUDE_API_KEY=your_claude_api_key_here

# Server Configuration
PORT=3001

# Environment (development|production)
NODE_ENV=development

# Logging Level (ERROR|WARN|INFO|DEBUG)
LOG_LEVEL=INFO

# CORS Configuration
# Frontend URL for CORS headers
FRONTEND_URL=http://localhost:5173

# Database (if needed in future)
# DATABASE_URL=postgresql://user:password@localhost:5432/cvadapt

# Security
# Set to true in production to enforce HTTPS redirects
FORCE_HTTPS=false

# Session/Auth (if needed in future)
# SESSION_SECRET=your_secret_key_here
